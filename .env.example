# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# =========================
# Team2 Phase 2 (BFF / Upstream)
# =========================
# Optional: 공통 공공데이터 API 키. 도메인별 키가 없으면 이 값을 사용합니다.
TEAM2_PUBLIC_API_KEY=""
# Optional: API 키를 쿼리에 실을 파라미터명 (기본 serviceKey)
TEAM2_PUBLIC_API_KEY_PARAM="serviceKey"
# Optional: 업스트림 요청 타임아웃(ms)
TEAM2_UPSTREAM_TIMEOUT_MS="8000"

# 도메인별 업스트림 URL (설정하지 않으면 mock payload 자동 사용)
# 서울 실시간 돌발정보 예시: http://openapi.seoul.go.kr:8088/{KEY}/xml/AccInfo/1/200/
TEAM2_TRAFFIC_UPSTREAM_URL=""
TEAM2_WEATHER_UPSTREAM_URL=""
TEAM2_DISASTER_UPSTREAM_URL=""
TEAM2_INFRA_UPSTREAM_URL=""
TEAM2_CRIME_UPSTREAM_URL=""
TEAM2_HEALTH_UPSTREAM_URL=""
TEAM2_VULNERABLE_UPSTREAM_URL=""

# Optional: 도메인별 개별 API 키 (설정 시 공통 키보다 우선)
# Optional: 서울특별시 실시간 돌발 정보 전용 키 (traffic 도메인에서 최우선 사용)
TEAM2_TRAFFIC_SEOUL_INCIDENT_API_KEY=""
# Optional: URL 템플릿 사용 시 traffic 전용 파라미터
TEAM2_TRAFFIC_UPSTREAM_TYPE="xml"
TEAM2_TRAFFIC_UPSTREAM_SERVICE="AccInfo"
TEAM2_TRAFFIC_UPSTREAM_START_INDEX="1"
TEAM2_TRAFFIC_UPSTREAM_END_INDEX="200"

# Optional: 공용 디지털트윈(VWorld) API 키/도메인
TEAM2_DIGITAL_TWIN_API_KEY=""
TEAM2_DIGITAL_TWIN_API_DOMAIN=""
# Optional: 조회 범위 및 페이지 사이즈 (기본: BOX(124,33,132,39), 1000)
# Optional: OpenSky Network 실시간 항공기 데이터 (Basic Auth)
TEAM2_AVIATION_OPENSKY_CLIENT_ID=""
TEAM2_AVIATION_OPENSKY_CLIENT_SECRET=""
TEAM2_AVIATION_OPENSKY_BBOX="33,124,39,132"
TEAM2_AVIATION_OPENSKY_POLL_MS="15000"

TEAM2_AVIATION_NO_FLY_GEOM_FILTER="BOX(124,33,132,39)"
TEAM2_AVIATION_NO_FLY_PAGE_SIZE="1000"
# Optional: CCTV 조회 범위/페이지/속성 필터 (LT_P_UTISCCTV)
TEAM2_CCTV_GEOM_FILTER="BOX(124,33,132,39)"
TEAM2_CCTV_PAGE_SIZE="1000"
TEAM2_CCTV_ATTR_FILTER=""
# Optional: UTIC CCTV 영상 스트림 (개방데이터 신청/승인 후 사용)
TEAM2_UTIC_CCTV_API_KEY=""
TEAM2_UTIC_CCTV_BASE_URL="https://www.utic.go.kr/guide/cctvOpenData.do"

TEAM2_TRAFFIC_API_KEY=""
TEAM2_WEATHER_API_KEY=""
TEAM2_DISASTER_API_KEY=""
# Optional: 산불 발생 지점 API 전용 키 (없으면 TEAM2_DISASTER_API_KEY 사용)
TEAM2_DISASTER_WILDFIRE_API_KEY=""
# Optional: 산불 발생 지점 API URL/페이지 설정 (기본: 최근 1년)
TEAM2_DISASTER_WILDFIRE_UPSTREAM_URL="http://apis.data.go.kr/1400000/forestStusService/getfirestatsservice"
TEAM2_DISASTER_WILDFIRE_PAGE_SIZE="500"
TEAM2_DISASTER_WILDFIRE_MAX_PAGES="20"
TEAM2_INFRA_API_KEY=""
TEAM2_CRIME_API_KEY=""
TEAM2_HEALTH_API_KEY=""
# Optional: 응급실 위치(기관별 위경도) 실데이터 API URL
TEAM2_HEALTH_EMERGENCY_ROOMS_UPSTREAM_URL="https://apis.data.go.kr/B552657/ErmctInsttInfoInqireService/getEgytListInfoInqire"
# Optional: 응급실 위치 API 페이지 크기/최대 페이지
TEAM2_HEALTH_EMERGENCY_ROOMS_PAGE_SIZE="1000"
TEAM2_HEALTH_EMERGENCY_ROOMS_MAX_PAGES="20"
TEAM2_VULNERABLE_API_KEY=""
